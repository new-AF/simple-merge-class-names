{
    "name": "simple-merge-class-names",
    "version": "9.1.0",
    "description": " A class names merger for TypeScript, JavaScript, TSX, and JSX (React)",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "types": "./dist/index.d.mts"
        }
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "files": [
        "dist",
        "LICENSE.txt",
        "README.md"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsup",
        "prepublishOnly": "pnpm tsup",
        "test": "vitest",
        "test:watch": "vitest run --watch",
        "test:ui": "vitest --ui"
    },
    "keywords": [
        "class-names-merger",
        "classes-merger",
        "jsx",
        "merge",
        "mergeClassNames",
        "mergeClassNamesDebugger",
        "merger",
        "react",
        "tailwindcss",
        "tsx",
        "utility"
    ],
    "author": "Abdullah Fatota",
    "license": "AGPL-3.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/new-AF/simple-merge-class-names.git"
    },
    "homepage": "https://github.com/new-AF/simple-merge-class-names",
    "devDependencies": {
        "tsup": "^8.5.1",
        "typescript": "^6.0.3",
        "vitest": "^3.2.3"
    }
}
